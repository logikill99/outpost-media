# Optional: override the listen port (defaults to 5000).
# On macOS, Control Center / AirPlay Receiver squats on 5000 — set PORT=5001 for local dev.
# PORT=5000

SECRET_KEY=your-secret-key-here
ADMIN_PASSWORD=change-me-before-event
CTF_FLAG_WELCOME=FLAG{your_welcome_flag_here}
CTF_FLAG_PITWALL=FLAG{your_pitwall_flag_here}
CTF_FLAG_STEG=FLAG{your_steg_flag_here}
CTF_FLAG_CAESAR=FLAG{your_caesar_flag_here}
CTF_FLAG_BLACKBOX=FLAG{your_blackbox_flag_here}
CTF_FLAG_FINALLAP=FLAG{your_finallap_flag_here}
